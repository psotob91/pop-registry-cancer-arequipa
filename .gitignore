.Renviron
.Renviron*
.env
.env.*
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
credentials*
token*
tokens*
auth*
secrets*
service-account*.json
*secret*.json
*token*.json

# ============================================================
# 1. DATOS CRUDOS Y DERIVADOS (NO PÚBLICOS)
# ============================================================

DATA/
data/

# ============================================================
# 2. TABULARES / BASES / DATOS (IGNORAR POR DEFECTO)
# ============================================================

*.csv
*.tsv
*.xlsx
*.xls
*.ods
*.rds
*.rda
*.RData
*.parquet
*.feather
*.fst
*.qs

# JSON: ignorar por defecto, luego abrir excepciones estructurales
*.json

# ============================================================
