# ============================================================

.Rhistory
.RData
.Ruserdata
.Rproj.user/

# ============================================================
# 6. SISTEMA / ENTORNOS
# ============================================================

.DS_Store
Thumbs.db
desktop.ini
.venv/
venv/
__pycache__/
node_modules/
renv/library/
renv/staging/
renv/python/

# ============================================================
# 7. EXCEPCIONES: CÓDIGO Y DOCUMENTACIÓN ESTRUCTURAL
# ============================================================

!SCRIPTS/
!SCRIPTS/**
!R/
!R/**
!scripts/
!scripts/**
!src/
!src/**
!inst/
!inst/**

!*.Rproj
!.gitignore
!README.md
!README.qmd
!LICENSE
!renv.lock

!*.md
!*.txt
!*.yaml
!*.yml
!*.qmd
!*.toml
!*.ini
!*.css
!*.scss

# ============================================================
# 8. EXCEPCIONES: MANIFIESTOS / METADATA ESTRUCTURAL
# ============================================================

!META_MANIFESTS/
!META_MANIFESTS/**
!metadata/
!metadata/**
!config/
!config/**
!inst/extdata/
!inst/extdata/**

# CSV maestros / metadata
!META_MANIFESTS/*.csv
!metadata/*.csv
!metadata/**/*.csv
!config/*.csv
!config/**/*.csv
!inst/extdata/*.csv
!inst/extdata/**/*.csv

# JSON/YAML estructurales
!META_MANIFESTS/*.json
!metadata/*.json
!metadata/**/*.json
!config/*.json
!config/**/*.json
!*.json
!*.yaml
!*.yml

# ============================================================
# 9. EXCEPCIONES ESPECÍFICAS DEL PROYECTO
# ============================================================

# Maestros esperados por scripts
!DATA/DERIVED/METADATA/
!DATA/DERIVED/METADATA/*.csv
!REPORTS/METADATA/
!REPORTS/METADATA/*.csv

# Si agregas manifiestos de datos/código
!MASTER_FILE_INDEX.csv
!DATA_REGISTRY.csv
!CODE_MANIFEST.csv

# ============================================================
# 10. REPORTS: NO subir CSV de outputs, salvo metadata estructural
# ============================================================

!REPORTS/
REPORTS/*.csv
REPORTS/*.json
REPORTS/*.pdf
REPORTS/*.html
REPORTS/*.docx
REPORTS/*.pptx
REPORTS/*_files/

!REPORTS/*.md
!REPORTS/*.qmd
!REPORTS/*.txt
!REPORTS/METADATA/
!REPORTS/METADATA/**
!REPORTS/SPECS/
!REPORTS/SPECS/**